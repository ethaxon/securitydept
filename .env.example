# Env vars use `__` as the nesting separator.
# Examples:
#   SERVER__HOST -> server.host
#   OIDC__CLIENT_ID -> oidc.client_id
#   SESSION_CONTEXT__COOKIE_NAME -> session_context.cookie_name
#   CREDS_MANAGE__DATA_PATH -> creds_manage.data_path
#
# Complex arrays / tables such as basic_auth_context.users, basic_auth_context.zones,
# or real_ip_resolve.providers/sources are better configured in config.toml.

## Meta
# SECURITYDEPT_CONFIG=./config.toml
# RUST_LOG=info

## Server bind and static files
# SERVER__HOST=0.0.0.0
# SERVER__PORT=7021
# SERVER__WEBUI_DIR=./webui
# SERVER__EXTERNAL_BASE_URL=auto
# SERVER__EXTERNAL_BASE_URL=https://auth.example.com

## WebUI dev server proxy target (vite)
# VITE_BACKEND_URL=http://localhost:7021

## Session context / cookie settings
# SESSION_CONTEXT__COOKIE_NAME=securitydept_session
# SESSION_CONTEXT__SESSION_CONTEXT_KEY=securitydept.session_context
# SESSION_CONTEXT__COOKIE_PATH=/
# SESSION_CONTEXT__HTTP_ONLY=true
# SESSION_CONTEXT__SECURE=false
# SESSION_CONTEXT__SAME_SITE=lax
# SESSION_CONTEXT__TTL=1d
# SESSION_CONTEXT__POST_AUTH_REDIRECT__DEFAULT_REDIRECT_TARGET=/
# SESSION_CONTEXT__POST_AUTH_REDIRECT__DYNAMIC_REDIRECT_TARGET_ENABLED=true

## OIDC
## Set to false to disable OIDC entirely and fall back to dev session login.
# OIDC_ENABLED=false
OIDC__CLIENT_ID=your-client-id
OIDC__CLIENT_SECRET=your-client-secret
OIDC__WELL_KNOWN_URL=https://your-oidc-provider.com/.well-known/openid-configuration
# OIDC__SCOPES=openid profile email
# OIDC__REDIRECT_URL=/auth/callback
# OIDC__CLAIMS_CHECK_SCRIPT=./claims-script-check.mts
# OIDC__PKCE_ENABLED=true
# OIDC__DEVICE_POLL_INTERVAL=5s

## Optional direct endpoint overrides.
# OIDC__ISSUER_URL=https://your-oidc-provider.com
# OIDC__AUTHORIZATION_ENDPOINT=https://your-oidc-provider.com/authorize
# OIDC__TOKEN_ENDPOINT=https://your-oidc-provider.com/token
# OIDC__USERINFO_ENDPOINT=https://your-oidc-provider.com/userinfo
# OIDC__JWKS_URI=https://your-oidc-provider.com/jwks

## Optional pending OAuth store tuning.
# OIDC__PENDING_STORE__TTL=5m
# OIDC__PENDING_STORE__MAX_CAPACITY=1000

## Token-set context
# TOKEN_SET_CONTEXT__SEALED_REFRESH_TOKEN=true
# TOKEN_SET_CONTEXT__MASTER_KEY=01234567890123456789012345678901
# TOKEN_SET_CONTEXT__METADATA_REDEMPTION__TTL=60s
# TOKEN_SET_CONTEXT__METADATA_REDEMPTION__MAX_CAPACITY=1000
# TOKEN_SET_CONTEXT__POST_AUTH_REDIRECT__DYNAMIC_REDIRECT_TARGET_ENABLED=true
# TOKEN_SET_CONTEXT__TOKEN_PROPAGATION__DEFAULT_POLICY=validate_then_forward

## Creds-manage storage
# CREDS_MANAGE__DATA_PATH=./data/data.json

## Basic-auth dashboard context
# BASIC_AUTH_CONTEXT__REALM=securitydept
# BASIC_AUTH_CONTEXT__POST_AUTH_REDIRECT__DEFAULT_REDIRECT_TARGET=/
# BASIC_AUTH_CONTEXT__REAL_IP_ACCESS__ALLOW_FALLBACK=false

## Propagation forwarder
# PROPAGATION_FORWARDER__PROXY_PATH=/
