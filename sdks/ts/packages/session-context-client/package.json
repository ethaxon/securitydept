{
	"name": "@securitydept/session-context-client",
	"version": "0.2.0-beta.6",
	"description": "Session Context Client of the SecurityDept TypeScript SDK, a layered authentication and authorization toolkit built as reusable Rust crates, a TypeScript client SDK workspace, and reference server/web apps.",
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ethaxon/securitydept.git",
		"directory": "sdks/ts/packages/session-context-client"
	},
	"homepage": "https://securitydept.ethaxon.com/",
	"bugs": {
		"url": "https://github.com/ethaxon/securitydept/issues"
	},
	"keywords": [
		"securitydept",
		"auth",
		"authentication",
		"authorization",
		"oidc",
		"oauth",
		"sdk",
		"typescript",
		"token",
		"credentials"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"monorepo-tsc": "./src/index.ts",
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./web": {
			"monorepo-tsc": "./src/web/index.ts",
			"types": "./dist/web/index.d.mts",
			"import": "./dist/web/index.mjs"
		},
		"./server": {
			"monorepo-tsc": "./src/server/index.ts",
			"types": "./dist/server/index.d.mts",
			"import": "./dist/server/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@securitydept/client": "workspace:*"
	}
}
