{
	"name": "@securitydept/token-set-context-client",
	"version": "0.2.0-beta.6",
	"description": "Token Set Context Client of the SecurityDept TypeScript SDK, a layered authentication and authorization toolkit built as reusable Rust crates, a TypeScript client SDK workspace, and reference server/web apps.",
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ethaxon/securitydept.git",
		"directory": "sdks/ts/packages/token-set-context-client"
	},
	"homepage": "https://securitydept.ethaxon.com/",
	"bugs": {
		"url": "https://github.com/ethaxon/securitydept/issues"
	},
	"keywords": [
		"securitydept",
		"auth",
		"authentication",
		"authorization",
		"oidc",
		"oauth",
		"sdk",
		"typescript",
		"token",
		"credentials"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./backend-oidc-mode": {
			"monorepo-tsc": "./src/backend-oidc-mode/index.ts",
			"types": "./dist/backend-oidc-mode/index.d.mts",
			"import": "./dist/backend-oidc-mode/index.mjs"
		},
		"./backend-oidc-mode/web": {
			"monorepo-tsc": "./src/backend-oidc-mode/web/index.ts",
			"types": "./dist/backend-oidc-mode/web/index.d.mts",
			"import": "./dist/backend-oidc-mode/web/index.mjs"
		},
		"./frontend-oidc-mode": {
			"monorepo-tsc": "./src/frontend-oidc-mode/index.ts",
			"types": "./dist/frontend-oidc-mode/index.d.mts",
			"import": "./dist/frontend-oidc-mode/index.mjs"
		},
		"./orchestration": {
			"monorepo-tsc": "./src/orchestration/index.ts",
			"types": "./dist/orchestration/index.d.mts",
			"import": "./dist/orchestration/index.mjs"
		},
		"./access-token-substrate": {
			"monorepo-tsc": "./src/access-token-substrate/index.ts",
			"types": "./dist/access-token-substrate/index.d.mts",
			"import": "./dist/access-token-substrate/index.mjs"
		},
		"./registry": {
			"monorepo-tsc": "./src/registry/index.ts",
			"types": "./dist/registry/index.d.mts",
			"import": "./dist/registry/index.mjs"
		},
		"./web-router": {
			"monorepo-tsc": "./src/web-router/index.ts",
			"types": "./dist/web-router/index.d.mts",
			"import": "./dist/web-router/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@securitydept/client": "workspace:*"
	},
	"peerDependencies": {
		"oauth4webapi": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"oauth4webapi": {
			"optional": true
		}
	}
}
