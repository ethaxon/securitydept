{
	"name": "@securitydept/token-set-context-client-react",
	"version": "0.2.0",
	"description": "Token Set Context Client React of the SecurityDept TypeScript SDK, a layered authentication and authorization toolkit built as reusable Rust crates, a TypeScript client SDK workspace, and reference server/web apps.",
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ethaxon/securitydept.git",
		"directory": "sdks/ts/packages/token-set-context-client-react"
	},
	"homepage": "https://securitydept.ethaxon.com/",
	"bugs": {
		"url": "https://github.com/ethaxon/securitydept/issues"
	},
	"keywords": [
		"securitydept",
		"auth",
		"authentication",
		"authorization",
		"oidc",
		"oauth",
		"sdk",
		"typescript",
		"token",
		"credentials"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"monorepo-tsc": "./src/index.tsx",
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./react-query": {
			"monorepo-tsc": "./src/react-query/index.ts",
			"types": "./dist/react-query/index.d.mts",
			"import": "./dist/react-query/index.mjs"
		},
		"./tanstack-router": {
			"monorepo-tsc": "./src/tanstack-router/index.ts",
			"types": "./dist/tanstack-router/index.d.mts",
			"import": "./dist/tanstack-router/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@securitydept/client": "workspace:*",
		"@securitydept/client-react": "workspace:*",
		"@securitydept/token-set-context-client": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"@tanstack/react-query": ">=5.0.0"
	},
	"peerDependenciesMeta": {
		"@tanstack/react-query": {
			"optional": true
		}
	},
	"devDependencies": {
		"@tanstack/react-query": "^5.90.2"
	}
}
