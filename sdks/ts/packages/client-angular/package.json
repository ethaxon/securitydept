{
	"name": "@securitydept/client-angular",
	"version": "0.2.0-beta.3",
	"description": "Client Angular of the SecurityDept TypeScript SDK, a layered authentication and authorization toolkit built as reusable Rust crates, a TypeScript client SDK workspace, and reference server/web apps.",
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ethaxon/securitydept.git",
		"directory": "sdks/ts/packages/client-angular"
	},
	"homepage": "https://securitydept.ethaxon.com/",
	"bugs": {
		"url": "https://github.com/ethaxon/securitydept/issues"
	},
	"keywords": [
		"securitydept",
		"auth",
		"authentication",
		"authorization",
		"oidc",
		"oauth",
		"sdk",
		"typescript",
		"token",
		"credentials"
	],
	"type": "module",
	"sideEffects": false,
	"publishConfig": {
		"directory": "dist",
		"linkDirectory": false
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"monorepo-tsc": "./src/public-api.ts",
			"types": "./dist/types/securitydept-client-angular.d.ts",
			"default": "./dist/fesm2022/securitydept-client-angular.mjs"
		}
	},
	"scripts": {
		"build": "ng-packagr -p ng-package.json -c tsconfig.lib.json"
	},
	"peerDependencies": {
		"@securitydept/client": "workspace:*",
		"@angular/core": ">=19.0.0",
		"@angular/router": ">=19.0.0",
		"rxjs": ">=7.0.0"
	},
	"devDependencies": {
		"@securitydept/client": "workspace:*"
	}
}
