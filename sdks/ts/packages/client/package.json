{
	"name": "@securitydept/client",
	"version": "0.2.0",
	"description": "Client of the SecurityDept TypeScript SDK, a layered authentication and authorization toolkit built as reusable Rust crates, a TypeScript client SDK workspace, and reference server/web apps.",
	"author": "Zhou Yeheng <root@aitiotekt.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ethaxon/securitydept.git",
		"directory": "sdks/ts/packages/client"
	},
	"homepage": "https://securitydept.ethaxon.com/",
	"bugs": {
		"url": "https://github.com/ethaxon/securitydept/issues"
	},
	"keywords": [
		"securitydept",
		"auth",
		"authentication",
		"authorization",
		"oidc",
		"oauth",
		"sdk",
		"typescript",
		"token",
		"credentials"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"monorepo-tsc": "./src/index.ts",
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./persistence": {
			"monorepo-tsc": "./src/persistence/index.ts",
			"types": "./dist/persistence/index.d.mts",
			"import": "./dist/persistence/index.mjs"
		},
		"./persistence/web": {
			"monorepo-tsc": "./src/persistence/web/index.ts",
			"types": "./dist/persistence/web/index.d.mts",
			"import": "./dist/persistence/web/index.mjs"
		},
		"./web": {
			"monorepo-tsc": "./src/web/index.ts",
			"types": "./dist/web/index.d.mts",
			"import": "./dist/web/index.mjs"
		},
		"./events": {
			"monorepo-tsc": "./src/events/index.ts",
			"types": "./dist/events/index.d.mts",
			"import": "./dist/events/index.mjs"
		},
		"./auth-coordination": {
			"monorepo-tsc": "./src/auth-coordination/index.ts",
			"types": "./dist/auth-coordination/index.d.mts",
			"import": "./dist/auth-coordination/index.mjs"
		},
		"./web-router": {
			"monorepo-tsc": "./src/web-router/index.ts",
			"types": "./dist/web-router/index.d.mts",
			"import": "./dist/web-router/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc -b"
	},
	"dependencies": {
		"@standard-schema/spec": "^1.0.0",
		"rxjs": "^7.8.2"
	}
}
