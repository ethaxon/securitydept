{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"types": ["node"]
	},
	"include": [
		".vitepress/**/*.ts",
		".vitepress/**/*.mts",
		".vitepress/**/*.tsx",
		"scripts/**/*.ts"
	],
	"exclude": [".vitepress/cache", ".vitepress/dist", "node_modules"]
}
