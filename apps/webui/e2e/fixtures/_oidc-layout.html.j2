<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title | escape }}</title>
    <style>
        :root {
            color-scheme: light;
            font-family: "IBM Plex Sans", "Segoe UI", sans-serif;
            background: #f4efe8;
            color: #1d1d1b;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(195, 118, 54, 0.18), transparent 30%),
                linear-gradient(180deg, #f4efe8 0%, #efe7dc 100%);
            display: grid;
            place-items: center;
            padding: 24px;
        }

        main {
            width: min(100%, 420px);
            border: 1px solid rgba(29, 29, 27, 0.08);
            border-radius: 24px;
            background: rgba(255, 252, 247, 0.92);
            box-shadow: 0 24px 80px rgba(86, 59, 34, 0.12);
            padding: 28px;
        }

        h1 {
            margin: 0 0 8px;
            font-size: 1.8rem;
            line-height: 1.1;
        }

        p {
            margin: 0 0 20px;
            color: #5d5245;
            line-height: 1.55;
        }

        label {
            display: block;
            margin-bottom: 12px;
            font-size: 0.92rem;
            font-weight: 600;
        }

        input {
            box-sizing: border-box;
            width: 100%;
            margin-top: 6px;
            border: 1px solid rgba(29, 29, 27, 0.12);
            border-radius: 14px;
            padding: 12px 14px;
            font: inherit;
            background: white;
        }

        button {
            width: 100%;
            border: 0;
            border-radius: 14px;
            padding: 12px 14px;
            font: inherit;
            font-weight: 700;
            color: white;
            background: #0f766e;
            cursor: pointer;
        }

        .hint {
            margin-top: 16px;
            font-size: 0.82rem;
            color: #7b6a59;
        }

        .error {
            margin-bottom: 16px;
            border-radius: 14px;
            background: #fff0ef;
            color: #9f2f24;
            padding: 12px 14px;
            font-size: 0.92rem;
        }

        .details {
            margin: 16px 0 0;
            padding: 0;
            color: #7b6a59;
        }

        .details dt {
            margin: 0 0 4px;
            font-size: 0.82rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .details dd {
            margin: 0 0 12px;
        }

        code {
            font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
        }
    </style>
</head>

<body>
    <main>
        {% block content %}{% endblock %}
    </main>
</body>

</html>