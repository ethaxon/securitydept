{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"paths": {
			"@/*": ["./src/*"]
		},
		"target": "es2022",
		"lib": ["esnext", "dom"],
		"jsx": "react-jsx"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"**/node_modules",
		"**/dist",
		"src/**/__tests__/**/*.ts",
		"src/**/__tests__/**/*.tsx"
	]
}
